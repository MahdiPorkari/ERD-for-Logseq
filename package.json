{
  "name": "logseq-plugin-outline-canvas",
  "author": "logseq-dev",
  "version": "1.0.0",
  "description": "Renders hierarchical block trees as interactive visual diagrams using Canvas2D",
  "license": "MIT",
  "homepage": "https://github.com/hdansou/logseq-outline-canvas#readme",
  "bugs": {
    "url": "https://github.com/hdansou/logseq-outline-canvas/issues"
  },
  "keywords": [
    "logseq",
    "logseq-plugin",
    "diagram",
    "mind-map",
    "tree",
    "treemap",
    "fishbone",
    "roadmap",
    "canvas",
    "visualization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hdansou/logseq-outline-canvas"
  },
  "main": "dist/index.html",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "logseq": {
    "id": "logseq-plugin-outline-canvas",
    "title": "OutlineCanvas",
    "icon": "./icon.png",
    "main": "dist/index.html",
    "unsupportedGraphType": "file"
  },
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      [
        "@semantic-release/github",
        {
          "assets": [
            "logseq-plugin-outline-canvas.zip"
          ]
        }
      ]
    ]
  },
  "devDependencies": {
    "@logseq/libs": "^0.3.3",
    "typescript": "^5.0.0",
    "vite": "^8.0.10",
    "vite-plugin-logseq": "^1.1.2"
  },
  "overrides": {
    "dompurify": "^3.4.2",
    "lodash-es": "^4.18.1"
  }
}
